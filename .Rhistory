rBivarCop <- function(n, marg1, m1, c1, marg2, m2, c2, cop, tau) {
## error checking
if(!is.numeric(n) | n <= 0) {
stop("Please specify a valid input for sample size n.")}
else if(!is.numeric(marg1) | !(marg1 %in% c(1, 2))) {
stop("marg1 must be 1 or 2.")}
else if(!is.numeric(m1) | m1 <= 0) {
stop("m1 must be a positive number.")}
else if(!is.numeric(c1) | c1 <= 0) {
stop("c1 must be a positive number.")}
else if(!is.numeric(marg2) | !(marg2 %in% c(1, 2))) {
stop("marg2 must be 1 or 2.")}
else if(!is.numeric(m2) | m2 <= 0) {
stop("m2 must be a positive number.")}
else if(!is.numeric(c2) | c2 <= 0) {
stop("c2 must be a positive number.")}
else if(!is.numeric(cop) | !(cop %in% c(1, 2, 3, 4))) {
stop("cop must be an integer between 1 and 4.")}
else if(!is.numeric(tau) | tau < 0 | tau >= 1) {
stop("tau must be between 0 and 1.")}
## convert from mean and variance to model parameters
if (marg1 == 1L){ ## gamma shape and rate
a1 <- 1/c1^2; b1 <- 1/(m1*c1^2)
} else if (marg1 == 2L){ ## lognormal mean and sd
s1 <- sqrt(log(1 + c1^2)); mu1  <- log(m1) - 0.5*s1^2
}
if (marg2 == 1L){
a2 <- 1/c2^2; b2 <- 1/(m2*c2^2)
} else if (marg2 == 2L){
s2 <- sqrt(log(1 + c2^2)); mu2  <- log(m2) - 0.5*s2^2
}
## sample from a copula
if(cop == 1L) { ## independence
u1 <- stats::runif(n); u2 <- stats::runif(n)
} else if(cop == 2L) { ## Clayton
theta <- 2*tau/(1-tau) ## convert from tau to theta
u.temp <- copula::rCopula(n, copula::claytonCopula(theta)) ## use copula package
u1 <- as.numeric(u.temp[,1]); u2 <- as.numeric(u.temp[,2])
} else if (cop == 3L){  ## Gaussian
theta <- sin(pi*tau/2)
z1 <- stats::rnorm(n) ## convert Gaussian to unit scale
z2 <- stats::rnorm(n, theta*z1, sqrt(1-theta^2))
u1 <- stats::pnorm(z1); u2 <- stats::pnorm(z2)
} else if (cop == 4L){  ## Gumbel
theta <- 1/(1-tau) ## use copula package to generate
u.temp <- copula::rCopula(n, copula::gumbelCopula(theta))
u1 <- as.numeric(u.temp[,1]); u2 <- as.numeric(u.temp[,2])
}
x <- matrix(0, nrow = n, ncol = 2)
## copula observation to marignals
if(marg1 == 1L) {
x[,1] <- stats::qgamma(u1, shape=a1, rate=b1)
} else {
x[,1] <- stats::qlnorm(u1, meanlog=mu1, sdlog=s1)
}
if(marg2 == 1L) {
x[,2] <- stats::qgamma(u2, shape=a2, rate=b2)
} else {
x[,2] <- stats::qlnorm(u2, meanlog=mu2, sdlog=s2)
}
return(x)
}
dataGen <- function(n = 18, gs = c(6, 4, 4, 4), marg1, marg2, cop, hier = TRUE,
hyper_mu, hyper_prec, mus_nohier = NULL, sigmas_nohier = NULL,
seed = 1){
## error checking
if(!is.numeric(n) | n <= 0) {
stop("Please specify a valid input for sample size n.")}
else if(!is.numeric(gs) | sum(!((gs %% 1)==0)) > 0 | sum(gs <= 1) > 0) {
stop("All group sizes in gs must be postitive integers >= 2.")}
else if(n != sum(gs)) {
stop("The total sample size for all groups in gs must sum to n.")}
else if(!is.numeric(marg1) | !(marg1 %in% c(1, 2))) {
stop("marg1 must be 1 or 2.")}
else if(!is.numeric(marg2) | !(marg2 %in% c(1, 2))) {
stop("marg2 must be 1 or 2.")}
else if(!is.numeric(cop) | !(cop %in% c(1, 2, 3, 4))) {
stop("cop must be an integer between 1 and 4.")}
else if(!(hier %in% c(TRUE, FALSE))) {
stop("Please provide a boolean input for hier.")}
if(!is.null(seed) & (!is.numeric(seed) | length(seed) != 1)) {
stop("Please specify a valid seed for random number generation.")}
else if (!is.null(seed)){
if (seed%%1 != 0){
stop("Please specify a valid seed for random number generation.")}
}
if (hier == TRUE){
if(!is.numeric(hyper_mu) | length(hyper_mu != 6)) {
stop("Please provide six valid parameters for the hyperprior means")}
else if(!is.numeric(hyper_prec) | length(hyper_prec != 6)) {
stop("Please provide six valid parameters for the hyperprior precisions")}
} else {
if(!is.numeric(mus_nohier) | length(mus_nohier != 5)) {
stop("Please provide five valid parameters for the parameter means across doses")}
else if(!is.numeric(sigmas_nohier) | length(sigmas_nohier != 5)) {
stop("Please provide five valid parameters for the parameter SDs across doses")}
}
set.seed(seed)
## get number of doses
G <- length(gs)
dose <- rep(1:G, gs)
if (hier == FALSE){
## extract hyperparameters from inputs
mu_m1 <- mus_nohier[1]; mu_m2 <- mus_nohier[2]
mu_c1 <- mus_nohier[3]; mu_c2 <- mus_nohier[4]
mu_logittau <- mus_nohier[5]
sigma_m1 <- sigmas_nohier[1]; sigma_m2 <- sigmas_nohier[2]
sigma_c1 <- sigmas_nohier[3]; sigma_c2 <- sigmas_nohier[4]
sigma_logittau <- sigmas_nohier[5]
}
if (hier){
## simulate parameters from hierarchical structure
mu_m1 <- stats::rnorm(1, hyper_mu[1], 1/sqrt(hyper_prec[1]))
mu_m2 <- stats::rnorm(1, hyper_mu[1], 1/sqrt(hyper_prec[1]))
mu_c1 <- stats::rnorm(1, hyper_mu[2], 1/sqrt(hyper_prec[2]))
mu_c2 <- stats::rnorm(1, hyper_mu[2], 1/sqrt(hyper_prec[2]))
mu_logittau <- stats::rnorm(1, hyper_mu[3], 1/sqrt(hyper_prec[3]))
sigma_m1 <- truncnorm::rtruncnorm(1, a = 0, b = Inf, hyper_mu[4], 1/sqrt(hyper_prec[4]))
sigma_m2 <- truncnorm::rtruncnorm(1, a = 0, b = Inf, hyper_mu[4], 1/sqrt(hyper_prec[4]))
sigma_c1 <- truncnorm::rtruncnorm(1, a = 0, b = Inf, hyper_mu[5], 1/sqrt(hyper_prec[5]))
sigma_c2 <- truncnorm::rtruncnorm(1, a = 0, b = Inf, hyper_mu[5], 1/sqrt(hyper_prec[5]))
sigma_logittau <- truncnorm::rtruncnorm(1, a = 0, b = Inf, hyper_mu[6], 1/sqrt(hyper_prec[6]))
}
m1 <- NULL; m2 <- NULL; c1 <- NULL; c2 <- NULL
logit_tau <- NULL; tau <- NULL
for (g in 1:G) {
m1[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_m1, sd = sigma_m1)
m2[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_m2, sd = sigma_m2)
c1[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_c1, sd = sigma_c1)
c2[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_c2, sd = sigma_c2)
logit_tau[g] <- stats::rnorm(1, mu_logittau, sigma_logittau)
tau[g] <- 1/(1 + exp(-logit_tau[g]))
}
## repeat over doses
m1 <- m1[dose]
c1 <- c1[dose]
m2 <- m2[dose]
c2 <- c2[dose]
tau <- tau[dose]
## generate the bivariate observations using rBivarCop
y_obs <- lapply(1:n,
function(i) { rBivarCop(n = 1, marg1 = marg1, m1 = m1[i],
c1 = c1[i], marg2 = marg2, m2 = m2[i],
c2 = c2[i], cop = cop, tau = tau[i])})
y_obs <- do.call(rbind, y_obs)
## define constants and data
constants <- list(N = n, G = G, group = dose)
data <- list(y = y_obs)
params <- list(unique(m1), unique(c1), unique(m2), unique(c2), unique(tau))
## return list used later for NIMBLE
return(list(constants, data, params))
}
dataGen(n = 18, gs = c(6, 4, 4, 4), marg1 = 1, marg2 = 1,
cop = 1, hyper_mu = c(1, 0.5, 0.25, 0.2, 0.1, 0.25),
hyper_prec = c(400, 400, 20, 800, 800, 20), seed = 1)
