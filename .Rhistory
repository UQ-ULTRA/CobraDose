else if(!is.numeric(sigmas_nohier) | length(sigmas_nohier) != 5) {
stop("Please provide five valid parameters for the parameter SDs across doses")}
}
set.seed(seed)
## get number of doses
G <- length(gs)
dose <- rep(1:G, gs)
if (hier == FALSE){
## extract hyperparameters from inputs
mu_m1 <- mus_nohier[1]; mu_m2 <- mus_nohier[2]
mu_c1 <- mus_nohier[3]; mu_c2 <- mus_nohier[4]
mu_logittau <- mus_nohier[5]
sigma_m1 <- sigmas_nohier[1]; sigma_m2 <- sigmas_nohier[2]
sigma_c1 <- sigmas_nohier[3]; sigma_c2 <- sigmas_nohier[4]
sigma_logittau <- sigmas_nohier[5]
}
