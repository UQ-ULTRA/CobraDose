logit_tau <- NULL; tau <- NULL
for (g in 1:G) {
m1[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_m1, sd = sigma_m1)
m2[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_m2, sd = sigma_m2)
c1[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_c1, sd = sigma_c1)
c2[g] <- truncnorm::rtruncnorm(1, a = 1e-6, b = Inf, mean = mu_c2, sd = sigma_c2)
logit_tau[g] <- stats::rnorm(1, mu_logittau, sigma_logittau)
tau[g] <- 1/(1 + exp(-logit_tau[g]))
}
## repeat over doses
m1 <- m1[dose]
c1 <- c1[dose]
m2 <- m2[dose]
c2 <- c2[dose]
tau <- tau[dose]
## generate the bivariate observations using rBivarCop
y_obs <- lapply(1:n,
function(i) { rBivarCop(n = 1, marg1 = marg1, m1 = m1[i],
c1 = c1[i], marg2 = marg2, m2 = m2[i],
c2 = c2[i], cop = cop, tau = tau[i])})
y_obs <- do.call(rbind, y_obs)
## define constants and data
constants <- list(N = n, G = G, group = dose)
data <- list(y = y_obs)
params <- list(m1 = unique(m1), c1 = unique(c1), m2 = unique(m2), c2 = unique(c2), tau = unique(tau))
## return list used later for NIMBLE
return(list(Constants = constants, Responses = data, Parmeters = params))
}
tt = dataGen(n = 18, gs = c(6, 4, 4, 4), marg1 = 1, marg2 = 1,
cop = 1, hyper_mu = c(1, 0.5, 0.25, 0.2, 0.1, 0.25),
hyper_prec = c(400, 400, 20, 800, 800, 20), seed = 1)
tt
tt[[3]]
tt[[2]]
check()
library(devtools)
devtools::document()
devtools::install()
library(CobraDose)
rBivarCop(n = 5, marg1 = 1, m1 = 1, c1 = 0.5, marg2 = 2, m2 = 1.2, c2 = 0.65,
cop = 2, tau = 0.5)
dataGen(n = 18, gs = c(6, 4, 4, 4), marg1 = 1, marg2 = 1,
cop = 1, hyper_mu = c(1, 0.5, 0.25, 0.2, 0.1, 0.25),
hyper_prec = c(400, 400, 20, 800, 800, 20), seed = 1)
devtools::check()
build_manual()
uninstall("CobraDose")
remove.packages("CobraDose")
devtools::install()
library(CobraDose)
?dataGen
